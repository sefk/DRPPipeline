# Copy to .env and fill in your API keys.
#   cp .env.example .env

# Anthropic API key — required to use the default "DRP Pipeline (Claude)" spec.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key — optional; lets you pick GPT-4/GPT-5 models in the UI.
OPENAI_API_KEY=

# Host port for the LibreChat UI. Change if 3081 is already in use.
LIBRECHAT_PORT=3081

# MeiliSearch master key — any long random string. Keep consistent across
# container restarts so the existing search index keeps working.
MEILI_MASTER_KEY=drp_meili_dev_key_change_me

# LibreChat crypto secrets. Defaults are acceptable for a local demo but you
# should regenerate for any shared deployment:
#   openssl rand -hex 32   # for CREDS_KEY, JWT_SECRET, JWT_REFRESH_SECRET
#   openssl rand -hex 16   # for CREDS_IV
CREDS_KEY=f34be427ebb29de8d88c107a71546019685ed8b241d8f2ed00c3df97ad2566f0
CREDS_IV=e2341419ec3dd3d19b13a1a87fafcbfb
JWT_SECRET=16f8c0ef4a5d391b26034086c628469d3f9f497f08163ab9b40137092f2909ef
JWT_REFRESH_SECRET=eaa5191d9c2f78aac2e4e12e87bfb45e42289c9086ab8e5671a10e5b41487a76
